# AWS IoT MQTT
MQTT_ENDPOINT=your-endpoint.iot.region.amazonaws.com
MQTT_PORT=8883
MQTT_CLIENT_ID=your-client-id
MQTT_TOPIC=your/mqtt/topic
MQTT_CERT_PATH=/path/to/cert.pem
MQTT_KEY_PATH=/path/to/private.key
MQTT_CA_PATH=/path/to/root-CA.crt

# AWS CloudWatch
CLOUDWATCH_NAMESPACE=Nepenthes

# SwitchBot API
SB_TOKEN=your-switchbot-api-token
SB_SECRET_KEY=your-switchbot-secret-key

# System
NEPENTHES_SCRIPT_PATH=/path/to/nepenthes.py
BT_INTERFACE=hci0
